#!/usr/bin/env bash
# Tracked git hook (configured via `git config core.hooksPath .githooks`).
set -e

# 1) Version single-source-of-truth: pyproject.toml and the VS Code extension must agree.
#    Stops a half-bumped commit before it reaches CI (which would refuse to tag).
py=$(sed -nE 's/^version *= *"([^"]+)".*/\1/p' pyproject.toml | head -1)
ext=$(sed -nE 's/.*"version" *: *"([^"]+)".*/\1/p' vscode-extension/package.json | head -1)
if [ -n "$ext" ] && [ "$py" != "$ext" ]; then
    echo "[hook] FAIL: version mismatch — pyproject.toml=$py but vscode-extension/package.json=$ext"
    echo "[hook]   fix both at once:  python -m interact.versioning bump <major|minor|patch>"
    exit 1
fi

# git runs hooks with a minimal PATH (the login shell — incl. nvm's shims — isn't sourced), which
# is why node/npm/npx/json2ts were "not found" here. Load the user's nvm default the same way an
# interactive shell would, so the node steps below behave identically. Returns non-zero (handled
# by callers) if node still can't be found, so the commit degrades gracefully offline / in CI.
_load_node() {
    command -v node >/dev/null 2>&1 && return 0
    export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
    if [ -s "$NVM_DIR/nvm.sh" ]; then
        set +e  # nvm.sh can emit non-zero lines; don't let `set -e` abort the commit
        # shellcheck disable=SC1091
        . "$NVM_DIR/nvm.sh" --no-use >/dev/null 2>&1
        nvm use default >/dev/null 2>&1 || nvm use node >/dev/null 2>&1
        set -e
    fi
    command -v node >/dev/null 2>&1
}

# 2) Regenerate TS bindings when the Pydantic API surface changes (keeps the committed
#    generated/types.ts in lock-step with the models).
if git diff --cached --name-only | grep -qE '^src/interact/(models|formats|api_types)\.py$|^src/interact/benchmarks/(published|upstream)\.py$'; then
    if _load_node; then
        echo "[hook] Pydantic API changed — regenerating TS types..."
        if bash vscode-extension/scripts/generate-types.sh >/dev/null 2>&1; then
            git add vscode-extension/src/generated/types.ts 2>/dev/null || true
        else
            echo "[hook] WARN: type generation failed, continuing"
        fi
    else
        echo "[hook] WARN: node not found (nvm not loadable) — skipping TS type regen"
    fi
fi

# 3) Typecheck + build the VS Code extension when its source changes — the real gate that catches
#    TS errors before they land. (Packaging/installing the .vsix is a separate manual step, not
#    done here: the .vsix is gitignored, so rebuilding it every commit just burns time.)
if git diff --cached --name-only | grep -q "^vscode-extension/"; then
    if _load_node; then
        echo "[hook] Extension source changed — typechecking (npm run compile)..."
        if ! (cd vscode-extension && npm run compile >/dev/null 2>&1); then
            echo "[hook] FAIL: extension does not compile — fix before committing"
            echo "[hook]   run: (cd vscode-extension && npm run compile)   to see the errors"
            exit 1
        fi
        echo "[hook] Extension compiles."
    else
        echo "[hook] WARN: node not found (nvm not loadable) — skipping extension typecheck"
    fi
fi
