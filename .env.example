# interact configuration — all optional (interact runs zero-config). Copy to `.env` for a
# project-local override, or set the same keys in ~/.interact/config.env (via `interact` / the
# config TUI) for a user-wide one. Your real `.env` is gitignored — keep API keys here, never commit.
#
# Precedence (first wins):  host env  >  ~/.interact/config.env  >  project .env  >  built-in defaults
# So anything "dev-specific" you don't want baked into the codebase lives HERE and overrides the
# clean defaults — colleagues who don't set it get the production behaviour.

# --- Vision model + provider keys (only needed for the VLM analysis features) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# GEMINI_API_KEY=...
# INTERACT_IMAGE_MODEL=          # e.g. gemini/gemini-2.5-flash — empty = tested recommendation
# INTERACT_VIDEO_MODEL=
# INTERACT_COMPONENT_MODEL=      # element detection; falls back to the image model when empty

# --- Browser ---
# INTERACT_HEADLESS=true
# INTERACT_BROWSER_TYPE=chromium # chromium | firefox | webkit

# --- Desktop sandbox (Linux/X11) ---
# INTERACT_DESKTOP_TARGET=local  # local (real session) | nested (isolated Xephyr/Xvfb)
# INTERACT_NESTED_DISPLAY=99
# INTERACT_NESTED_SIZE=1280x800
# INTERACT_NESTED_HEADLESS=false # true → Xvfb (servers/CI, no window); false → Xephyr (watch it)

# --- Output / debug ---
# INTERACT_DEBUG_DIR=~/.interact # usage log + screenshot dumps relocate with this

# --- DEV ONLY — run a local interact checkout instead of the released build ---
# The VS Code extension (and `interact.projectPath` setting) reads this to run your working tree
# via `uv run`. Leave UNSET for any normal/colleague install so the released build is used; it is
# never auto-detected from an open workspace.
# INTERACT_PROJECT_PATH=/home/you/dev/interact
